# アプリ設定
DEBUG=false
DATABASE_URL=sqlite:///./network_monitor.db
ALLOWED_ORIGINS=http://localhost:5173

# 監視設定
DEFAULT_PING_INTERVAL_SECONDS=60
MIN_PING_INTERVAL_SECONDS=10
MAX_PING_INTERVAL_SECONDS=3600
HISTORY_RETENTION_HOURS=24
PING_TIMEOUT_SECONDS=2.0

# Slack通知（任意）
# Slack Incoming Webhook URL を設定するとダウン検知時に通知が届きます。
# 未設定（空欄）の場合は通知を送信しません。
SLACK_WEBHOOK_URL=
